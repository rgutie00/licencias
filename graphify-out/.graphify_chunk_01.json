    {
      "id": "concept_license_activation",
      "label": "License Activation Flow",
      "file_type": "rationale",
      "source_file": "activate.html",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "The activation flow collects NIT (company tax ID), company name, and license type (commercial or trial/30-day), then binds the license to the server MAC address. This server-binding ensures the license cannot be reused on other machines."
    },
    {
      "id": "concept_tamper_detection",
      "label": "License Tamper and Clock-Skew Detection",
      "file_type": "rationale",
      "source_file": "license_system/templates/license/activate.html",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Two invalidation reasons are explicitly modelled: 'tampered' (license file corrupted or modified) and 'clock' (system clock was rolled back to bypass expiry). Both trigger forced re-activation, preventing offline time-manipulation attacks."
    },
