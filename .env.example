# .env.example — Servidor Central de Licencias
# Copiar a .env y completar los valores reales.
# NUNCA commitear el .env real (está en .gitignore).
#
# Desarrollo:  DEBUG=True  → los secretos pueden quedar con valores de prueba.
# Producción:  DEBUG=False → DJANGO_SECRET_KEY, LICENSE_SECRET_KEY y
#              LICENSE_AGENT_API_KEY son OBLIGATORIOS o la app no arranca.

# Django
DEBUG=False
DJANGO_SECRET_KEY=cambiar-por-clave-aleatoria-larga
ALLOWED_HOSTS=tu-dominio.com,www.tu-dominio.com

# Base de datos (PostgreSQL en producción; si se omite usa SQLite local)
DATABASE_URL=postgresql://usuario:password@host:5432/licencias_db

# Sistema de licencias
# CRÍTICO: LICENSE_SECRET_KEY debe ser idéntica a la del proyecto cliente.
LICENSE_SECRET_KEY=clave-secreta-compartida-con-clientes
LICENSE_AGENT_API_KEY=api-key-de-los-agentes-clientes

# Duración de licencias (días)
LICENSE_COMMERCIAL_DAYS=365
LICENSE_TRIAL_DAYS=30
